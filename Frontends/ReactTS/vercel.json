{
  "framework": "vite",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/health", "destination": "https://horuseye-api.mauricioadachi.dev/health" },
    { "source": "/api/(.*)", "destination": "https://horuseye-api.mauricioadachi.dev/api/$1" },
    { "source": "/hubs/(.*)", "destination": "https://horuseye-api.mauricioadachi.dev/hubs/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
